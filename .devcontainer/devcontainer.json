// https://aka.ms/devcontainer.json
{
    "name": "Laravel Nuxt UI",
    "dockerComposeFile": [
        "../docker-compose.dev.yml"
    ],
    "service": "laravel",
    "workspaceFolder": "/var/www/html",
    "mounts": [
        "type=bind,source=${localEnv:HOME}/.ssh,target=/home/www-data/.ssh,readonly",
        "type=bind,source=${localEnv:HOME}/.gitconfig,target=/home/www-data/.gitconfig,readonly"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "DEVSENSE.phptools-vscode",
                "MehediDracula.php-namespace-resolver",
                "xdebug.php-debug",
                "laravel.vscode-laravel",
                "Vue.volar",
                "hollowtree.vue-snippets",
                "dbaeumer.vscode-eslint",
                "EditorConfig.EditorConfig",
                "bradlc.vscode-tailwindcss",
                "eamodio.gitlens",
                "mikestead.dotenv",
                "streetsidesoftware.code-spell-checker",
                "shd101wyy.markdown-preview-enhanced",
                "formulahendry.auto-rename-tag",
                "pmneo.tsimporter"
            ],
            "settings": {
                "html.format.wrapAttributes": "force-expand-multiline",
                "js/ts.preferences.quoteStyle": "single",
                "js/ts.format.semicolons": "remove",
                "[vue]": {
                    "editor.defaultFormatter": "Vue.volar",
                    "editor.tabSize": 4
                }
            }
        }
    },
    "remoteUser": "www-data",
    // "forwardPorts": [],
    // "runServices": [],
    // "shutdownAction": "none",
}
